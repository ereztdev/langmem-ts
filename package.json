{
  "name": "langmem-ts",
  "version": "0.1.0",
  "description": "TypeScript-native memory primitive for AI agents",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
       "type": "git",
       "url": "https://github.com/ereztdev/langmem-ts.git"
  },
  "keywords": [
    "memory",
    "ai",
    "agent",
    "llm",
    "rag",
    "pgvector",
    "embeddings",
    "langchain-alternative",
    "typescript",
    "postgres"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "openai": ">=4",
    "pg": ">=8"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.12",
    "dotenv": "^16.5.0",
    "openai": "^6.34.0",
    "pg": "^8.14.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
